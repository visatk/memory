{
	"name": "tools",
	"version": "1.0.0",
	"private": true,
	"type": "module",
	"scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "npm run build && vite preview",
    "deploy": "npm run db:generate && npm run db:migrate:remote && wrangler types && npm run build && wrangler deploy",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply forum --local",
    "db:migrate:remote": "wrangler d1 migrations apply forum --remote",
    "db:studio": "drizzle-kit studio"
  },
	"dependencies": {
		"@marsidev/react-turnstile": "^1.5.0",
		"@tailwindcss/vite": "^4.2.2",
		"@hono/zod-validator": "^0.7.6",
		"react": "^19.2.4",
		"react-router-dom": "^7.14.0",
		"drizzle-orm": "^0.45.2",
		"zod": "^3.24.4",
		"lucide-react": "^1.8.0",
		"hono": "^4.12.9",
		"tailwindcss": "^4.2.2",
		"react-dom": "^19.2.4",
		"react-markdown": "^9.0.1",
		"remark-gfm": "^4.0.0"
	},
	"devDependencies": {
		"@cloudflare/vite-plugin": "^1.31.0",
		"@types/node": "^22.0.0",
		"@faker-js/faker": "^10.4.0",
		"@types/cloudflare-turnstile": "^0.2.2",
		"@cloudflare/workers-types": "latest",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"typescript": "^6.0.2",
		"vite": "^8.0.3",
		"drizzle-kit": "^0.31.10",
		"tsx": "^4.21.0",
		"wrangler": "^4.80.0"
	}
}
