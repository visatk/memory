{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "memory",
  "main": "./src/index.ts",
  "compatibility_date": "2026-04-14",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "not_found_handling": "single-page-application",
    "run_worker_first": [
      "/api/*"
    ]
  },
  "observability": {
    "enabled": true
  }
}
