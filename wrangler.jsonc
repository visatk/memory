{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "devkit",
  "main": "./src/index.ts",
  "workers_dev": false,
  "account_id": "7416e7b5d307baabca87e8fba69158e5",
  "compatibility_date": "2026-04-14",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "route": {
    "pattern": "www.visatk.us/*",
    "zone_name": "visatk.us",
  },
  "assets": {
    "not_found_handling": "single-page-application",
    "run_worker_first": [
      "/api/*"
    ]
  },
  "observability": {
    "enabled": true
  },
  "placement": {
    "mode": "smart",
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "forum",
      "database_id": "ac8aa89b-786a-47df-8b7a-d5f9eca96b33"
    }
  ]
}
